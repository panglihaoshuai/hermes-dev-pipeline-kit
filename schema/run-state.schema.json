{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/nousresearch/hermes-dev-pipeline-kit/schema/run-state.schema.json",
  "title": "Run State",
  "description": "Pipeline execution state snapshot for hermes-dev-pipeline-kit. Captures gate progression, classification, work orders, verification results, and approval status.",
  "type": "object",
  "required": [
    "run_id",
    "project",
    "mode",
    "current_gate",
    "classification",
    "work_orders",
    "allowed_files",
    "forbidden_files",
    "modified_files",
    "command_evidence",
    "codex",
    "verification",
    "acceptance",
    "approval_gates",
    "report_scale",
    "owner_summary_required",
    "stage_update_required",
    "responsibility_trace_required",
    "approval_inbox_required",
    "baseline_debt",
    "follow_up_backlog"
  ],
  "additionalProperties": false,
  "properties": {
    "run_id": {
      "type": "string",
      "description": "Unique identifier for this pipeline run (UUID or ISO 8601 timestamp).",
      "minLength": 1
    },
    "status": {
      "type": "string",
      "description": "Harness-level run outcome.",
      "enum": ["completed", "partial", "failed"]
    },
    "failed_phase": {
      "type": "string",
      "description": "Phase that failed, if this run ended in failure."
    },
    "failed_command": {
      "type": "string",
      "description": "Command that failed, if available."
    },
    "failed_exit_code": {
      "type": ["integer", "null"],
      "description": "Exit code for the failed command, if available."
    },
    "failure_reason": {
      "type": "string",
      "description": "Human-readable failure reason."
    },
    "project": {
      "type": "string",
      "description": "Project path or name being processed.",
      "minLength": 1
    },
    "mode": {
      "type": "string",
      "description": "Pipeline execution mode.",
      "enum": ["dry_run", "plan_only", "auto_run"]
    },
    "current_gate": {
      "type": "string",
      "description": "Current pipeline gate (e.g. 'Gate 0', 'Gate 3.5', 'Gate 9').",
      "minLength": 1
    },
    "classification": {
      "type": "object",
      "description": "Task scale classification determined at Gate 0.",
      "required": ["scale", "reasons", "risk_level"],
      "additionalProperties": false,
      "properties": {
        "scale": {
          "type": "string",
          "description": "Task size classification.",
          "enum": ["S", "M", "L"]
        },
        "reasons": {
          "type": "array",
          "description": "Reasons for the assigned scale.",
          "items": {
            "type": "string"
          }
        },
        "risk_level": {
          "type": "string",
          "description": "Risk assessment level.",
          "enum": ["low", "medium", "high"]
        }
      }
    },
    "work_orders": {
      "type": "array",
      "description": "List of work orders (subtasks) for this run.",
      "items": {
        "type": "object",
        "required": ["id", "owner", "required_skill", "status", "files", "retries"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique work order identifier."
          },
          "owner": {
            "type": "string",
            "description": "Agent or user responsible for this work order."
          },
          "required_skill": {
            "type": "string",
            "description": "Skill required to execute this work order."
          },
          "required_matt_skill": {
            "type": "string",
            "description": "Matt skill ClaudeCode was required to use, if any.",
            "enum": ["tdd", "diagnose", "prototype", "to-issues", "grill-me"]
          },
          "skill_evidence": {
            "type": "object",
            "description": "Structured evidence that the required Matt skill was actually used.",
            "additionalProperties": true
          },
          "status": {
            "type": "string",
            "description": "Current status of the work order.",
            "enum": ["pending", "in_progress", "completed", "failed", "blocked"]
          },
          "files": {
            "type": "array",
            "description": "Files affected by this work order.",
            "items": {
              "type": "string"
            }
          },
          "retries": {
            "type": "integer",
            "description": "Number of retry attempts.",
            "minimum": 0
          }
        }
      }
    },
    "worker_results": {
      "type": "array",
      "description": "Harness-derived summaries of raw/worker/*.worker-result.json contracts. Worker results are evidence only and cannot mark final acceptance complete.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "work_order_id": { "type": "string" },
          "worker": { "type": "string" },
          "worker_skill": { "type": "string" },
          "status": { "type": "string" },
          "result_type": { "type": "string" },
          "review_verdict": { "type": "string" },
          "blocking_findings": {
            "type": "array",
            "items": { "type": "string" }
          },
          "deferred": { "type": "boolean" },
          "deferred_reason": { "type": "string" },
          "raw_output_path": { "type": "string" },
          "structured_output_path": { "type": "string" },
          "worker_attempted_acceptance": { "type": "boolean" },
          "worker_acceptance_complete": { "type": "boolean" }
        }
      }
    },
    "worker_result_contract": {
      "type": "object",
      "description": "Policy metadata for whether worker result evidence is required for this run.",
      "additionalProperties": false,
      "properties": {
        "required": { "type": "boolean" },
        "deferred_reason": { "type": "string" },
        "source": { "type": "string" }
      }
    },
    "worker_result_violations": {
      "type": "array",
      "description": "Harness-detected worker result contract violations.",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "properties": {
          "path": { "type": "string" },
          "violation": { "type": "string" }
        }
      }
    },
    "owner_summary": {
      "type": "object",
      "description": "Chinese owner-facing executive summary for the project owner / final approver.",
      "required": [
        "task",
        "status_color",
        "current_stage_label",
        "progress",
        "largest_risk",
        "needs_user_decision",
        "next_action"
      ],
      "additionalProperties": false,
      "properties": {
        "task": {
          "type": "string"
        },
        "status_color": {
          "type": "string",
          "enum": ["green", "yellow", "red", "绿", "黄", "红"]
        },
        "current_stage_label": {
          "type": "string"
        },
        "progress": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "intake": { "type": "string" },
            "planning": { "type": "string" },
            "work_order_split": { "type": "string" },
            "execution": { "type": "string" },
            "verification": { "type": "string" },
            "codex_review": { "type": "string" },
            "approval": { "type": "string" }
          }
        },
        "largest_risk": {
          "type": "string"
        },
        "needs_user_decision": {
          "type": "boolean"
        },
        "next_action": {
          "type": "string"
        }
      }
    },
    "stage_updates": {
      "type": "array",
      "description": "Chinese stage transition updates shown to the owner.",
      "items": {
        "type": "object",
        "required": ["from", "to", "tools_or_skills", "goal", "next_gate_condition", "needs_user_decision"],
        "additionalProperties": false,
        "properties": {
          "from": { "type": "string" },
          "to": { "type": "string" },
          "tools_or_skills": {
            "type": "array",
            "items": { "type": "string" }
          },
          "goal": { "type": "string" },
          "next_gate_condition": { "type": "string" },
          "needs_user_decision": { "type": "boolean" }
        }
      }
    },
    "responsibility_trace": {
      "type": "array",
      "description": "Responsibility ownership for task stages, approvals, evidence, and failures.",
      "items": {
        "type": "object",
        "required": ["item", "owner", "status", "evidence", "blocking"],
        "additionalProperties": false,
        "properties": {
          "item": { "type": "string" },
          "owner": {
            "type": "string",
            "enum": ["用户", "Owner", "Hermes", "ClaudeCode", "Codex", "worker adapters", "项目历史债"]
          },
          "status": { "type": "string" },
          "evidence": { "type": "string" },
          "blocking": { "type": "boolean" },
          "failure_owner": { "type": "string" }
        }
      }
    },
    "approval_inbox": {
      "type": "array",
      "description": "Concentrated owner approval items.",
      "items": {
        "type": "object",
        "required": ["id", "item", "why_approval_required", "recommendation", "impact_if_declined"],
        "additionalProperties": false,
        "properties": {
          "id": { "type": "string" },
          "item": { "type": "string" },
          "why_approval_required": { "type": "string" },
          "recommendation": { "type": "string" },
          "impact_if_declined": { "type": "string" }
        }
      }
    },
    "report_scale": {
      "type": "string",
      "description": "Chinese Report Scale Policy verbosity level for the owner-facing report.",
      "enum": ["compact", "standard", "full"]
    },
    "owner_summary_required": {
      "type": "boolean",
      "description": "Whether the owner-facing first-screen summary is required."
    },
    "stage_update_required": {
      "type": "boolean",
      "description": "Whether stage update narration is required for this task scale or state. Compact reports still require at least one structured stage update when accepted."
    },
    "responsibility_trace_required": {
      "type": "boolean",
      "description": "Whether responsibility trace is required because of scale, risk, failure, or blocker state. Accepted compact reports still require a compact responsibility trace."
    },
    "approval_inbox_required": {
      "type": "boolean",
      "description": "Whether approval items must be centralized in the approval inbox. Compact reports must still include approval_inbox, which may be an empty array for '无'."
    },
    "allowed_files": {
      "type": "array",
      "description": "Files this run is permitted to modify.",
      "items": {
        "type": "string"
      }
    },
    "forbidden_files": {
      "type": "array",
      "description": "Files this run must not modify.",
      "items": {
        "type": "string"
      }
    },
    "modified_files": {
      "type": "array",
      "description": "Files actually modified during this run.",
      "items": {
        "type": "string"
      }
    },
    "generated_files": {
      "type": "array",
      "description": "Files known to be generated artifacts. If any are modified, generation evidence is required.",
      "items": {
        "type": "string"
      }
    },
    "generation_command_evidence": {
      "type": "boolean",
      "description": "True when the run explicitly verified that generated files were produced by an official generation command."
    },
    "command_evidence": {
      "type": "array",
      "description": "Record of commands executed and their results.",
      "items": {
        "type": "object",
        "required": ["command", "exit_code", "key_output", "pass_fail"],
        "additionalProperties": false,
        "properties": {
          "command": {
            "type": "string",
            "description": "The command that was executed."
          },
          "exit_code": {
            "type": "integer",
            "description": "Exit code returned by the command."
          },
          "key_output": {
            "type": "string",
            "description": "Key output or summary from the command."
          },
          "pass_fail": {
            "type": "string",
            "description": "Whether the command passed or failed.",
            "enum": ["PASS", "FAIL"]
          }
        }
      }
    },
    "codex": {
      "type": "object",
      "description": "Codex review results. S-level tasks set verdicts to NOT_REQUIRED.",
      "required": ["plan_review_verdict", "diff_review_verdict", "disabled_by_user"],
      "additionalProperties": false,
      "properties": {
        "plan_review_verdict": {
          "type": "string",
          "description": "Verdict from Codex plan review.",
          "enum": ["PASS", "PASS_WITH_REQUIRED_CHANGES", "FAIL", "UNKNOWN", "NOT_REQUIRED"]
        },
        "diff_review_verdict": {
          "type": "string",
          "description": "Verdict from Codex diff review.",
          "enum": ["PASS", "PASS_WITH_REQUIRED_CHANGES", "FAIL", "UNKNOWN", "NOT_REQUIRED"]
        },
        "disabled_by_user": {
          "type": "boolean",
          "description": "Whether Codex review was explicitly disabled by the user."
        }
      }
    },
    "verification": {
      "type": "object",
      "description": "Verification results from final checks.",
      "required": ["git_diff_name_status", "git_diff_check_exit", "tests_pass", "typecheck_exit"],
      "additionalProperties": false,
      "properties": {
        "git_diff_name_status": {
          "type": "string",
          "description": "Output of git diff --name-status against baseline."
        },
        "git_diff_check_exit": {
          "type": "integer",
          "description": "Exit code from git diff --check (0 = no conflicts/issues)."
        },
        "tests_pass": {
          "type": "boolean",
          "description": "Whether all tests passed."
        },
        "typecheck_exit": {
          "type": ["integer", "null"],
          "description": "Exit code from typecheck command, or null if not applicable."
        }
      }
    },
    "acceptance": {
      "type": "object",
      "description": "Final acceptance status of the pipeline run.",
      "required": ["complete", "final_decision"],
      "additionalProperties": false,
      "properties": {
        "complete": {
          "type": "boolean",
          "description": "Whether the pipeline run completed all required gates."
        },
        "final_decision": {
          "type": "string",
          "description": "Final acceptance decision.",
          "enum": ["ACCEPTED", "NOT_ACCEPTED", "PARTIAL", "BLOCKED", "FAIL"]
        }
      }
    },
    "skill_trace": {
      "type": "object",
      "description": "Disclosure and evidence for active Hermes, ClaudeCode/Matt, Codex, policy, and verification skill/tool usage. Required by policy when acceptance.complete is true.",
      "required": [
        "entry_skill",
        "mode",
        "phase",
        "hermes_skills",
        "claudecode_skills",
        "codex_gates",
        "policy_check",
        "missing_evidence",
        "acceptance_impact"
      ],
      "additionalProperties": false,
      "properties": {
        "entry_skill": {
          "type": "string",
          "description": "Pipeline entry skill.",
          "const": "dev-pipeline-orchestrator"
        },
        "display_language": {
          "type": "string",
          "description": "Primary language for user-visible workflow narration.",
          "enum": ["zh-CN", "en-US"]
        },
        "current_phase_label": {
          "type": "string",
          "description": "Chinese user-facing label for the current phase."
        },
        "current_phase_internal": {
          "type": "string",
          "description": "Machine/internal phase key."
        },
        "user_visible_skill_banner": {
          "type": "boolean",
          "description": "Whether Hermes displayed the active workflow banner to the user."
        },
        "clarification_trace": {
          "type": "object",
          "description": "Chinese explanation of clarification questions and the next phase.",
          "additionalProperties": false,
          "properties": {
            "stage_label": {
              "type": "string"
            },
            "skills_used": {
              "type": "array",
              "items": {
                "type": "string"
              }
            },
            "why_questions_are_needed": {
              "type": "string"
            },
            "next_stage_label": {
              "type": "string"
            }
          }
        },
        "mode": {
          "type": "string",
          "enum": ["dry_run", "plan_only", "auto_run"]
        },
        "phase": {
          "type": "string",
          "enum": [
            "intake",
            "planning",
            "work order execution",
            "verification",
            "Codex review",
            "publish",
            "commit approval"
          ]
        },
        "hermes_skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "planned", "used", "evidence", "verdict"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "planned": {
                "type": "boolean"
              },
              "used": {
                "type": "boolean"
              },
              "evidence": {
                "type": "string"
              },
              "verdict": {
                "type": "string",
                "enum": ["PASS", "PARTIAL", "SKIPPED", "MISSING", "FAIL"]
              },
              "skipped_reason": {
                "type": "string"
              },
              "acceptance_impact": {
                "type": "string",
                "enum": ["none", "partial", "blocking"]
              }
            }
          }
        },
        "claudecode_skills": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "required", "reported", "evidence", "verdict"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string",
                "enum": ["tdd", "diagnose", "prototype", "to-issues", "grill-me"]
              },
              "required": {
                "type": "boolean"
              },
              "reported": {
                "type": "boolean"
              },
              "evidence": {
                "type": "object",
                "additionalProperties": true
              },
              "verdict": {
                "type": "string",
                "enum": ["PASS", "PARTIAL", "MISSING", "FAIL", "SKIPPED"]
              }
            }
          }
        },
        "codex_gates": {
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name", "required", "used", "verdict"],
            "additionalProperties": false,
            "properties": {
              "name": {
                "type": "string"
              },
              "required": {
                "type": "boolean"
              },
              "used": {
                "type": "boolean"
              },
              "verdict": {
                "type": "string",
                "enum": ["PASS", "PASS_WITH_REQUIRED_CHANGES", "SKIPPED", "FAIL", "UNKNOWN"]
              }
            }
          }
        },
        "policy_check": {
          "type": "object",
          "required": ["planned", "used", "exit_code"],
          "additionalProperties": false,
          "properties": {
            "planned": {
              "type": "boolean"
            },
            "used": {
              "type": "boolean"
            },
            "exit_code": {
              "type": ["integer", "null"]
            }
          }
        },
        "doctor_ci_local": {
          "type": "object",
          "additionalProperties": false,
          "properties": {
            "planned": {
              "type": "boolean"
            },
            "used": {
              "type": "boolean"
            },
            "commands": {
              "type": "array",
              "items": {
                "type": "object",
                "required": ["command", "exit_code"],
                "additionalProperties": false,
                "properties": {
                  "command": {
                    "type": "string"
                  },
                  "exit_code": {
                    "type": ["integer", "null"]
                  }
                }
              }
            }
          }
        },
        "missing_evidence": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "acceptance_impact": {
          "type": "string",
          "enum": ["none", "partial", "blocking"]
        }
      }
    },
    "approval_gates": {
      "type": "object",
      "description": "User approval status for destructive operations.",
      "required": ["commit_approved", "push_approved", "pr_approved", "repo_create_approved"],
      "additionalProperties": false,
      "properties": {
        "commit_approved": {
          "type": "boolean",
          "description": "Whether git commit was approved by user."
        },
        "push_approved": {
          "type": "boolean",
          "description": "Whether git push was approved by user."
        },
        "pr_approved": {
          "type": "boolean",
          "description": "Whether pull request creation was approved by user."
        },
        "repo_create_approved": {
          "type": "boolean",
          "description": "Whether repository creation was approved by user."
        }
      }
    },
    "baseline_debt": {
      "type": "array",
      "description": "Pre-existing technical debt acknowledged at run start.",
      "items": {
        "type": "object",
        "required": ["category", "description"],
        "additionalProperties": false,
        "properties": {
          "category": {
            "type": "string",
            "description": "Debt category (e.g. 'missing_tests', 'no_types', 'dead_code')."
          },
          "description": {
            "type": "string",
            "description": "Description of the debt item."
          }
        }
      }
    },
    "follow_up_backlog": {
      "type": "array",
      "description": "Items deferred to future runs.",
      "items": {
        "type": "object",
        "required": ["id", "category", "description", "blocker"],
        "additionalProperties": false,
        "properties": {
          "id": {
            "type": "string",
            "description": "Unique identifier for the backlog item."
          },
          "category": {
            "type": "string",
            "description": "Backlog category (e.g. 'refactor', 'test_coverage', 'documentation')."
          },
          "description": {
            "type": "string",
            "description": "Description of the follow-up item."
          },
          "blocker": {
            "type": "string",
            "description": "What blocks this item from being addressed now, or 'none' if just deferred."
          }
        }
      }
    },
    "mandatory_scale_classifier": {
      "type": "object",
      "description": "Scale classification enforcement",
      "properties": {
        "applied": { "type": "boolean" },
        "original_classification": { "type": "string", "enum": ["S", "M", "L"] },
        "corrected_classification": { "type": "string", "enum": ["S", "M", "L"] },
        "upgrade_reason": { "type": "string" }
      }
    },
    "claudecode_delegation": {
      "type": "object",
      "description": "M/L delegation enforcement",
      "properties": {
        "delegated": { "type": "boolean" },
        "waiver": { "type": "boolean" },
        "waiver_reason": { "type": "string" }
      }
    },
    "matt_evidence_gate": {
      "type": "object",
      "description": "Matt skill evidence enforcement",
      "properties": {
        "required_skill": { "type": "string" },
        "evidence_present": { "type": "boolean" },
        "evidence_type": { "type": "string", "enum": ["tdd", "diagnose", "prototype"] },
        "blocking": { "type": "boolean" }
      }
    },
    "codex_deferred": {
      "type": "object",
      "description": "Codex unavailable handling",
      "properties": {
        "deferred": { "type": "boolean" },
        "reason": { "type": "string" },
        "required": { "type": "boolean" }
      }
    },
    "vague_task": {
      "type": "boolean",
      "description": "Whether task is vague and requires intake"
    },
    "verification_exit_codes": {
      "type": "array",
      "description": "Exit codes from verification commands",
      "items": {
        "type": "object",
        "properties": {
          "command": { "type": "string" },
          "exit_code": { "type": "integer" },
          "pass": { "type": "boolean" }
        }
      }
    },
    "command_log_summary": {
      "type": "object",
      "description": "Harness-derived summary from raw/command-log.jsonl. Used for TDD RED/GREEN verification.",
      "additionalProperties": false,
      "properties": {
        "source": { "type": "string" },
        "red_exit_code": { "type": ["integer", "null"] },
        "green_exit_code": { "type": ["integer", "null"] },
        "red_command": { "type": "string" },
        "green_command": { "type": "string" },
        "tdd_sequence_verified": { "type": "boolean" }
      }
    },
    "raw_evidence": {
      "type": "object",
      "description": "Raw evidence file pointers and raw contract violation markers.",
      "additionalProperties": true,
      "properties": {
        "run_manifest": { "type": "string" },
        "classification": { "type": "string" },
        "command_log": { "type": "string" },
        "claudecode_result": { "type": "string" },
        "claudecode_result_contains_acceptance": { "type": "boolean" },
        "worker_results": {
          "type": "array",
          "items": { "type": "string" }
        },
        "worker_result_contains_acceptance": { "type": "boolean" },
        "worker_result_acceptance_complete": { "type": "boolean" }
      }
    },
    "state_source": {
      "type": "string",
      "description": "Whether this run-state was generated by the harness or hand-authored as a fixture.",
      "enum": ["generated", "policy_fixture", "legacy"]
    },
    "provenance": {
      "type": "object",
      "description": "Harness provenance for generated run-state.",
      "required": ["generated_by", "generated_at", "generator_version", "source_files"],
      "additionalProperties": false,
      "properties": {
        "generated_by": { "type": "string" },
        "generated_at": { "type": "string" },
        "generator_version": { "type": "string" },
        "source_files": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    }
  }
}
