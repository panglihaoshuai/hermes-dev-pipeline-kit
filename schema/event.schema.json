{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "https://github.com/nousresearch/hermes-dev-pipeline-kit/schema/event.schema.json",
  "title": "Hash-linked Harness Event",
  "type": "object",
  "required": [
    "seq",
    "run_id",
    "event_type",
    "state_before",
    "state_after",
    "actor",
    "timestamp",
    "artifact_paths",
    "artifact_hashes",
    "prev_event_hash",
    "event_hash"
  ],
  "additionalProperties": false,
  "properties": {
    "seq": { "type": "integer", "minimum": 1 },
    "run_id": { "type": "string", "minLength": 1 },
    "event_type": {
      "enum": [
        "RUN_INIT",
        "CLASSIFICATION_RECORDED",
        "INTAKE_RECORDED",
        "WORK_ORDER_CREATED",
        "CLAUDECODE_DELEGATED",
        "COMMAND_RECORDED_RED",
        "COMMAND_RECORDED_GREEN",
        "CLAUDECODE_RESULT_RECORDED",
        "RUN_FAILED",
        "RUN_STATE_GENERATED",
        "POLICY_CHECKED",
        "FINAL_REPORT_GENERATED",
        "APPROVAL_RECORDED",
        "RUN_COMPLETED"
      ]
    },
    "state_before": {
      "enum": [
        "NONE",
        "RUN_INITIALIZED",
        "CLASSIFIED",
        "INTAKE_RECORDED",
        "WORK_ORDER_CREATED",
        "CLAUDECODE_DELEGATED",
        "RED_RECORDED",
        "GREEN_RECORDED",
        "CLAUDECODE_RESULT_RECORDED",
        "FAILED",
        "RUN_STATE_GENERATED",
        "POLICY_CHECKED",
        "FINAL_REPORT_GENERATED",
        "APPROVAL_PENDING",
        "COMPLETED"
      ]
    },
    "state_after": {
      "enum": [
        "RUN_INITIALIZED",
        "CLASSIFIED",
        "INTAKE_RECORDED",
        "WORK_ORDER_CREATED",
        "CLAUDECODE_DELEGATED",
        "RED_RECORDED",
        "GREEN_RECORDED",
        "CLAUDECODE_RESULT_RECORDED",
        "FAILED",
        "RUN_STATE_GENERATED",
        "POLICY_CHECKED",
        "FINAL_REPORT_GENERATED",
        "APPROVAL_PENDING",
        "COMPLETED"
      ]
    },
    "actor": { "enum": ["harness", "Hermes", "ClaudeCode", "Codex", "Owner"] },
    "timestamp": { "type": "string", "minLength": 1 },
    "artifact_paths": {
      "type": "array",
      "description": "Immutable artifacts bound to this event. Command events must reference raw/commands/<command-id>.json plus stdout/stderr, not the append-only raw/command-log.jsonl index.",
      "items": { "type": "string" }
    },
    "artifact_hashes": {
      "type": "object",
      "description": "Full-file sha256 hashes for immutable event artifacts.",
      "additionalProperties": {
        "type": "string",
        "pattern": "^[a-f0-9]{64}$"
      }
    },
    "prev_event_hash": {
      "type": "string",
      "pattern": "^$|^[a-f0-9]{64}$"
    },
    "event_hash": {
      "type": "string",
      "pattern": "^[a-f0-9]{64}$"
    }
  }
}
